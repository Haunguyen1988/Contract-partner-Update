# Local development / long-running Node API:
# use the Supavisor session connection on port 5432.
DATABASE_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"

# Prisma migrations / schema changes:
# use the same session/direct connection on port 5432.
DIRECT_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"

# Optional future serverless runtime connection:
# if the backend later runs in a serverless / autoscaling environment,
# switch DATABASE_URL there to the transaction pooler on 6543.
DATABASE_URL_SERVERLESS="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

JWT_SECRET="change-me-in-production"
API_PORT=4000
WEB_PORT=3000
UPLOAD_DIR="./apps/api/uploads"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK="false"

# Optional future-ready variables if we later move web auth/session handling to Supabase SSR.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
