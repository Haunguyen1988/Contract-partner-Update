# Supabase runtime connection for serverless / auto-scaling environments.
# Use the Supavisor transaction pooler (port 6543) and append pgbouncer=true.
DATABASE_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct or session-mode connection for Prisma migrations / schema changes.
DIRECT_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"

JWT_SECRET="change-me-in-production"
API_PORT=4000
WEB_PORT=3000
UPLOAD_DIR="./apps/api/uploads"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Optional future-ready variables if we later move web auth/session handling to Supabase SSR.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
