# Internal Postgres for local development or LAN deployment.
# Example:
# DATABASE_URL="postgresql://contract_app:change-me@localhost:5432/contract_partner?schema=public"
DATABASE_URL="postgresql://[DB_USER]:[DB_PASSWORD]@[DB_HOST]:5432/[DB_NAME]?schema=public"

# Prisma migrations / schema changes.
# In an internal setup this is usually the same database with a direct connection.
DIRECT_URL="postgresql://[DB_USER]:[DB_PASSWORD]@[DB_HOST]:5432/[DB_NAME]?schema=public"

JWT_SECRET="change-me-in-production"
API_PORT=4000
WEB_PORT=3000
UPLOAD_DIR="./apps/api/uploads"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK="false"
